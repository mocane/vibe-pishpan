<Window x:Class="PishpanTimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PishpanTimeTracker"
        xmlns:viewmodels="clr-namespace:PishpanTimeTracker.ViewModels"
        xmlns:converters="clr-namespace:PishpanTimeTracker.Converters"
        mc:Ignorable="d"
        Title="Pishpan Time Tracker"
        SizeToContent="Height"
        MinHeight="300"
        Width="300"
        Background="#121212" Foreground="White" FontFamily="Segoe UI">
    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <converters:FileNameConverter x:Key="FileNameConverter"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Daily -->
            <RowDefinition Height="Auto"/> <!-- Pomodoro -->
            <RowDefinition Height="Auto"/> <!-- Bottom -->
          </Grid.RowDefinitions>
  
        <!-- Daily Task Tracker -->
        <Border Grid.Row="0" Background="#1e1e1e" CornerRadius="4" Padding="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding TaskTimeFormatted}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5"/>
                <TextBlock Text="{Binding WorkdayFinishTimeFormatted}" FontSize="18" Foreground="#42a5f5" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="Start" Command="{Binding StartTaskCommand}" Width="60" Background="#43a047"/>
                    <Button Content="+5 min" Command="{Binding AddFiveMinutesCommand}" Width="60" Background="#2196f3"/>
                    <Button Content="Stop" Command="{Binding StopTaskCommand}" Width="60" Background="#e53935"/>
                </StackPanel>

                <Separator Background="#333333" Margin="0,5"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><!-- make it a grid-->
                    <TextBlock Text="Workday Sound" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding AvailableSounds}" SelectedItem="{Binding SelectedWorkdaySoundPath}" Background="#2c2c2c" Foreground="White" BorderThickness="0" Padding="5">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Pomodoro Section -->
        <Expander Grid.Row="1" Header="Pomodoro" IsExpanded ="False" Background="#1e1e1e" Padding="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Pomodoro" FontSize="18" Foreground="#888888" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding PomodoroTimeFormatted}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Start" Command="{Binding StartPomodoroCommand}" Width="60" Background="#1e88e5"/>
                        <Button Content="Stop" Command="{Binding StopPomodoroCommand}" Width="60" Background="#e53935"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" Width="200">
                    <TextBlock Text="Duration (min)" Foreground="#888888" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding PomodoroDurationMinutes, UpdateSourceTrigger=PropertyChanged}" Background="#2c2c2c" Foreground="White" BorderThickness="0" Padding="5" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Sound" Foreground="#888888" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableSounds}" SelectedItem="{Binding SelectedSoundPath}" Background="#2c2c2c" Foreground="White" BorderThickness="0" Padding="5">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Expander>

        <!-- Bottom Section: Statistics -->
        <Expander Grid.Row="2" Header="Statistics" IsExpanded ="False" Background="#1e1e1e" Padding="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,0,10">
                    <TextBlock Text="Select Year" Foreground="#888888" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}" Width="100" Background="#2c2c2c" Foreground="White" BorderThickness="0" Padding="5" Margin="0,0,0,5"/>

                    <TextBlock Text="Select Month" Foreground="#888888" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding SelectedMonth}" Width="100" Background="#2c2c2c" Foreground="White" BorderThickness="0" Padding="5" Margin="0,0,0,5"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#2c2c2c" CornerRadius="4" Padding="5">
                    <StackPanel>
                        <TextBlock Text="Days Worked" Foreground="#888888" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DaysWorkedInSelectedMonth}" FontSize="48" FontWeight="Bold" Foreground="#42a5f5" HorizontalAlignment="Center" Margin="0,5"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Expander>
    </Grid>
</Window>
